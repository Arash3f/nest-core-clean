NODE_ENV=development

# Server Config
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=3000

# Swagger
SWAGGER_DOCS_PATH=docs
SWAGGER_PATH=api_docs

# JWT
JWT_SECRET=mySecasdas
jwtAccessExpire=10000
jwtRefreshExpire=10000

# Database
DATABASE_CONNECTION_URL=postgres://[username]:[password]@[127.0.0.1]:[5432]/[db-name]
DATABASE_NAME=[db-name]
DATABASE_USERNAME=[username]
DATABASE_PASSWORD=[password]
DATABASE_PORT=[5432]
DATABASE_HOST=[127.0.0.1]

SEED_ON_BOOT=true

# Super user default data
SUPER_USER_NAME=admin
SUPER_USER_USERNAME=admin
SUPER_USER_PASSWORD=admin

# Member user default data
MEMBER_USER_NAME=member
MEMBER_USER_USERNAME=member
MEMBER_USER_PASSWORD=member

# Uploads
UPLOAD_DIR=uploads

# Password hashing params
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_PARALLELISM=1

# Rate limiting for auth endpoints
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=10
