NODE_ENV=test

# ! Server Config
SERVER_ADDRESS=localhost
SERVER_PORT=3000

# ! Swagger Doc url pattern
SWAGGER_DOCS_PATH=docs
SWAGGER_PATH=api_docs

# ! CORS — comma-separated origins, or * for all
CORS_ORIGINS=*

# ! Rate limiting for auth endpoints (logIn, register, refreshToken)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=10

# ! JWT config section
JWT_SECRET=change-me-to-a-long-random-secret
jwtAccessExpire=10000
jwtRefreshExpire=10000

# ! Database config section
DATABASE_CONNECTION_URL=postgres://postgres:postgres@localhost:5432/nest_clean_core
DATABASE_NAME=nest_clean_core
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432
DATABASE_HOST=localhost

SEED_ON_BOOT=true

# ! Super user default data
SUPER_USER_NAME=admin
SUPER_USER_USERNAME=admin
SUPER_USER_PASSWORD=admin1234

# ! Member user default data (optional)
MEMBER_USER_NAME=member
MEMBER_USER_USERNAME=member
MEMBER_USER_PASSWORD=member1234

# ! Uploads (reserved for future file features)
UPLOAD_DIR=uploads

# ! Password hashing params
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_PARALLELISM=1
